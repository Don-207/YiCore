    spi1_sck: spi1-sck {
        compatible = "yi,stm32-pinmux";
        port = "GPIOA";
        pin = <5>;
        function = "spi-clock";
        mode = "alternate-push-pull";
        speed = "high";
        clocks = <&clk_gpioa>;
        init-level = "pre-kernel";
        init-priority = <20>;
        status = "okay";
    };

    spi1_miso: spi1-miso {
        compatible = "yi,stm32-pinmux";
        port = "GPIOA";
        pin = <6>;
        function = "spi-miso";
        mode = "input";
        pull = "none";
        clocks = <&clk_gpioa>;
        init-level = "pre-kernel";
        init-priority = <20>;
        status = "okay";
    };

    spi1_mosi: spi1-mosi {
        compatible = "yi,stm32-pinmux";
        port = "GPIOA";
        pin = <7>;
        function = "spi-mosi";
        mode = "alternate-push-pull";
        speed = "high";
        clocks = <&clk_gpioa>;
        init-level = "pre-kernel";
        init-priority = <20>;
        status = "okay";
    };

    uart0_tx: uart0-tx {
        compatible = "yi,stm32-pinmux";
        port = "GPIOA";
        pin = <9>;
        function = "uart-tx";
        mode = "alternate-push-pull";
        speed = "high";
        clocks = <&clk_gpioa>;
        status = "okay";
    };

    uart0_rx: uart0-rx {
        compatible = "yi,stm32-pinmux";
        port = "GPIOA";
        pin = <10>;
        function = "uart-rx";
        mode = "input";
        pull = "none";
        clocks = <&clk_gpioa>;
        status = "okay";
    };
